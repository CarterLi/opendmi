<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:dmi="http://opendmi.org/schema/opendmi.xsd"
           targetNamespace="http://opendmi.org/schema/opendmi.xsd"
           elementFormDefault="qualified">
    <xs:element name="dump" type="dmi:dumpType" />

    <xs:complexType name="dumpType">
        <xs:sequence>
            <xs:element name="entry" type="dmi:entryType" minOccurs="1" maxOccurs="1" />
            <xs:element name="table" type="dmi:tableType" minOccurs="0" />
        </xs:sequence>
        <xs:attribute name="createdAt" type="xs:dateTime" use="optional" />
    </xs:complexType>

    <xs:complexType name="entryType">
    </xs:complexType>

    <xs:complexType name="tableType">
    </xs:complexType>
</xs:schema>
